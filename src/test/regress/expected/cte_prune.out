         Output: sum(t1.v1), t1.v1
         Group Key: t1.v1
         ->  Hash Left Join
               Output: t1.v1
               Hash Cond: (t1.v1 = c22.v1)
               ->  Seq Scan on cte_prune.t1
                     Output: t1.v1, t1.v2, t1.v3
               ->  Hash
                     Output: c22.v1
                     ->  Subquery Scan on c22
                           Output: c22.v1
                           ->  Seq Scan on cte_prune.t1 t1_1
