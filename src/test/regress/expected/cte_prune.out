-------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)
   Output: t6.a, t6.b, t5_1.c, t5_1.d
   Merge Key: t6.a
   ->  Sort
         Output: t6.a, t6.b, t5_1.c, t5_1.d
         Sort Key: t6.a
         ->  Hash Join
               Output: t6.a, t6.b, t5_1.c, t5_1.d
               Hash Cond: (t5_1.c = t6.a)
               ->  Hash Join
                     Output: t5_1.c, t5_1.d
                     Hash Cond: (t5.c = t5_1.c)
                     ->  Hash Join
                           Output: t5.c, t5.d
                           Hash Cond: (t6_1.a = t5.c)
                           ->  Seq Scan on cte_prune.t6 t6_1
                                 Output: t6_1.a, t6_1.b
                                 Filter: ((t6_1.b < 5) AND (t6_1.a < 2))
                           ->  Hash
                                 Output: t5.c, t5.d
                                 ->  Seq Scan on cte_prune.t5
                                       Output: t5.c, t5.d
                                       Filter: (t5.c < 2)
                     ->  Hash
                           Output: t5_1.c, t5_1.d
                           ->  Hash Join
                                 Output: t5_1.c, t5_1.d
                                 Hash Cond: (t5_1.c = w.a)
                                 ->  Seq Scan on cte_prune.t5 t5_1
                                       Output: t5_1.c, t5_1.d
                                       Filter: ((t5_1.c < 2) AND (t5_1.d > 1))
                                 ->  Hash
                                       Output: w.a
                                       ->  Subquery Scan on w
                                             Output: w.a
                                             ->  Seq Scan on cte_prune.t6 t6_2
                                                   Output: t6_2.a, t6_2.b
                                                   Filter: ((t6_2.b < 5) AND (t6_2.a < 2))
               ->  Hash
                     Output: t6.a, t6.b
                     ->  Seq Scan on cte_prune.t6
                           Output: t6.a, t6.b
